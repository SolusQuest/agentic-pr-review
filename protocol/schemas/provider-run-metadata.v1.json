{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentic-pr-review/protocol/schemas/provider-run-metadata.v1.json",
  "title": "ProviderRunMetadataV1",
  "description": "Provider-neutral run metadata sidecar. Authoritative for serialization under the #29 design contract. Cross-field consistency, ordering, derivation equality, and identity agreement are enforced by the TypeScript semantic validator.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "selectedProviderId",
    "observedProviderId",
    "resolvedModelId",
    "adapterId",
    "logicalPrefixSha256",
    "prefixSha256",
    "capability",
    "cacheStatus",
    "normalizedUsage",
    "retryObservations",
    "errorCodes",
    "telemetryCompleteness",
    "producingRunId",
    "runAttempt",
    "interactionId",
    "consumedInputSha256",
    "resultSha256",
    "traceSha256",
    "predecessorLedgerSha256",
    "candidateLedgerSha256"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "selectedProviderId": { "$ref": "#/definitions/identityString" },
    "observedProviderId": { "$ref": "#/definitions/identityString" },
    "resolvedModelId": { "$ref": "#/definitions/identityString" },
    "adapterId": { "$ref": "#/definitions/hexDigest" },
    "logicalPrefixSha256": { "$ref": "#/definitions/hexDigest" },
    "prefixSha256": { "$ref": "#/definitions/hexDigest" },
    "capability": { "$ref": "#/definitions/capability" },
    "cacheStatus": { "$ref": "#/definitions/cacheStatusEnum" },
    "normalizedUsage": { "$ref": "#/definitions/normalizedUsage" },
    "retryObservations": { "$ref": "#/definitions/retryObservations" },
    "errorCodes": { "$ref": "#/definitions/errorCodeArray" },
    "telemetryCompleteness": { "$ref": "#/definitions/telemetryCompleteness" },
    "producingRunId": { "type": "string", "pattern": "^[1-9][0-9]{0,18}$" },
    "runAttempt": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "interactionId": { "$ref": "#/definitions/hexDigest" },
    "consumedInputSha256": { "$ref": "#/definitions/hexDigest" },
    "resultSha256": { "$ref": "#/definitions/hexDigest" },
    "traceSha256": { "$ref": "#/definitions/hexDigest" },
    "predecessorLedgerSha256": { "$ref": "#/definitions/predecessorLedgerRef" },
    "candidateLedgerSha256": { "$ref": "#/definitions/hexDigest" }
  },
  "definitions": {
    "identityString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "hexDigest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "predecessorLedgerRef": {
      "type": "string",
      "oneOf": [{ "pattern": "^[0-9a-f]{64}$" }, { "const": "bootstrap" }]
    },
    "tokenCount": {
      "type": ["integer", "null"],
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "capabilityEnum": {
      "type": "string",
      "enum": ["eligible", "ineligible", "unsupported", "telemetryUnavailable", "unknown"]
    },
    "cacheStatusEnum": {
      "type": "string",
      "enum": ["hit", "partial", "miss", "unsupported", "unknown"]
    },
    "outcomeEnum": {
      "type": "string",
      "enum": ["succeeded", "failed", "cancelled"]
    },
    "usageCompletenessAttempt": {
      "type": "string",
      "enum": ["complete", "partial", "missing"]
    },
    "usageCompletenessAggregate": {
      "type": "string",
      "enum": ["complete", "partial", "missing", "unknown"]
    },
    "statelessProofCompleteness": {
      "type": "string",
      "enum": ["notApplicable", "complete", "missing"]
    },
    "errorCode": {
      "type": "string",
      "enum": [
        "provider_timeout",
        "provider_4xx",
        "provider_5xx",
        "provider_rate_limited",
        "provider_cancelled",
        "capability_unsupported",
        "cache_marker_mismatch",
        "stateless_proof_missing"
      ]
    },
    "errorCodeArray": {
      "type": "array",
      "minItems": 0,
      "maxItems": 32,
      "items": { "$ref": "#/definitions/errorCode" }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "aggregate", "statelessProof"],
      "properties": {
        "mode": { "type": "string", "enum": ["standard", "stateless"] },
        "aggregate": { "$ref": "#/definitions/capabilityEnum" },
        "statelessProof": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "verified"],
              "properties": {
                "kind": { "type": "string", "enum": ["providerAdvertised", "synthetic"] },
                "verified": { "type": "boolean" }
              }
            }
          ]
        }
      }
    },
    "attemptObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestOrdinal",
        "attemptOrdinal",
        "outcome",
        "capability",
        "cacheStatus",
        "usageCompleteness",
        "totalInputTokens",
        "uncachedInputTokens",
        "cacheWriteInputTokens",
        "cacheReadInputTokens",
        "outputTokens",
        "attemptErrorCodes"
      ],
      "properties": {
        "requestOrdinal": { "type": "integer", "minimum": 0, "maximum": 32 },
        "attemptOrdinal": { "type": "integer", "minimum": 0, "maximum": 32 },
        "outcome": { "$ref": "#/definitions/outcomeEnum" },
        "capability": { "$ref": "#/definitions/capabilityEnum" },
        "cacheStatus": { "$ref": "#/definitions/cacheStatusEnum" },
        "usageCompleteness": { "$ref": "#/definitions/usageCompletenessAttempt" },
        "totalInputTokens": { "$ref": "#/definitions/tokenCount" },
        "uncachedInputTokens": { "$ref": "#/definitions/tokenCount" },
        "cacheWriteInputTokens": { "$ref": "#/definitions/tokenCount" },
        "cacheReadInputTokens": { "$ref": "#/definitions/tokenCount" },
        "outputTokens": { "$ref": "#/definitions/tokenCount" },
        "attemptErrorCodes": { "$ref": "#/definitions/errorCodeArray" }
      }
    },
    "requestObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestOrdinal",
        "capability",
        "cacheStatus",
        "usageCompleteness",
        "totalInputTokens",
        "uncachedInputTokens",
        "cacheWriteInputTokens",
        "cacheReadInputTokens",
        "outputTokens"
      ],
      "properties": {
        "requestOrdinal": { "type": "integer", "minimum": 0, "maximum": 32 },
        "capability": { "$ref": "#/definitions/capabilityEnum" },
        "cacheStatus": { "$ref": "#/definitions/cacheStatusEnum" },
        "usageCompleteness": { "$ref": "#/definitions/usageCompletenessAttempt" },
        "totalInputTokens": { "$ref": "#/definitions/tokenCount" },
        "uncachedInputTokens": { "$ref": "#/definitions/tokenCount" },
        "cacheWriteInputTokens": { "$ref": "#/definitions/tokenCount" },
        "cacheReadInputTokens": { "$ref": "#/definitions/tokenCount" },
        "outputTokens": { "$ref": "#/definitions/tokenCount" }
      }
    },
    "usageAggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalInputTokens",
        "uncachedInputTokens",
        "cacheWriteInputTokens",
        "cacheReadInputTokens",
        "outputTokens",
        "requestCount",
        "attemptCount"
      ],
      "properties": {
        "totalInputTokens": { "$ref": "#/definitions/tokenCount" },
        "uncachedInputTokens": { "$ref": "#/definitions/tokenCount" },
        "cacheWriteInputTokens": { "$ref": "#/definitions/tokenCount" },
        "cacheReadInputTokens": { "$ref": "#/definitions/tokenCount" },
        "outputTokens": { "$ref": "#/definitions/tokenCount" },
        "requestCount": { "type": "integer", "minimum": 0, "maximum": 32 },
        "attemptCount": { "type": "integer", "minimum": 0, "maximum": 32 }
      }
    },
    "normalizedUsage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempts", "requests", "aggregate"],
      "properties": {
        "attempts": {
          "type": "array",
          "minItems": 0,
          "maxItems": 32,
          "items": { "$ref": "#/definitions/attemptObservation" }
        },
        "requests": {
          "type": "array",
          "minItems": 0,
          "maxItems": 32,
          "items": { "$ref": "#/definitions/requestObservation" }
        },
        "aggregate": { "$ref": "#/definitions/usageAggregate" }
      }
    },
    "retryObservationRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestOrdinal",
        "attemptCount",
        "succeededCount",
        "failedCount",
        "cancelledCount"
      ],
      "properties": {
        "requestOrdinal": { "type": "integer", "minimum": 0, "maximum": 32 },
        "attemptCount": { "type": "integer", "minimum": 1, "maximum": 32 },
        "succeededCount": { "type": "integer", "minimum": 0, "maximum": 1 },
        "failedCount": { "type": "integer", "minimum": 0, "maximum": 32 },
        "cancelledCount": { "type": "integer", "minimum": 0, "maximum": 32 }
      }
    },
    "retryObservationAggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requestCount",
        "attemptCount",
        "succeededCount",
        "failedCount",
        "cancelledCount"
      ],
      "properties": {
        "requestCount": { "type": "integer", "minimum": 0, "maximum": 32 },
        "attemptCount": { "type": "integer", "minimum": 0, "maximum": 32 },
        "succeededCount": { "type": "integer", "minimum": 0, "maximum": 32 },
        "failedCount": { "type": "integer", "minimum": 0, "maximum": 32 },
        "cancelledCount": { "type": "integer", "minimum": 0, "maximum": 32 }
      }
    },
    "retryObservations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requests", "aggregate"],
      "properties": {
        "requests": {
          "type": "array",
          "minItems": 0,
          "maxItems": 32,
          "items": { "$ref": "#/definitions/retryObservationRequest" }
        },
        "aggregate": { "$ref": "#/definitions/retryObservationAggregate" }
      }
    },
    "telemetryCompleteness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["usage", "cache", "statelessProof", "aggregate"],
      "properties": {
        "usage": { "$ref": "#/definitions/usageCompletenessAggregate" },
        "cache": { "$ref": "#/definitions/usageCompletenessAggregate" },
        "statelessProof": { "$ref": "#/definitions/statelessProofCompleteness" },
        "aggregate": { "$ref": "#/definitions/usageCompletenessAggregate" }
      }
    }
  }
}
