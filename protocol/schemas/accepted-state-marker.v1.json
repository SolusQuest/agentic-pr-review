{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SolusQuest/agentic-pr-review/schemas/accepted-state-marker.v1.json",
  "title": "AcceptedStateMarkerV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "markerId",
    "candidateId",
    "registrationId",
    "stateKey",
    "sessionEpoch",
    "stateGeneration",
    "ledgerEpoch",
    "transition",
    "predecessorMarkerId",
    "predecessorManifestSha256",
    "predecessorLedgerSha256",
    "observedSelectorRevision",
    "manifestSha256",
    "candidateLedgerSha256",
    "providerRunMetadataSha256",
    "metadataSemanticSha256",
    "consumedInputSha256",
    "resultSha256",
    "traceSha256",
    "producingRunId",
    "producingRunAttempt",
    "acceptingRunId",
    "acceptingRunAttempt",
    "acceptedAt"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "markerId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "candidateId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "registrationId": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "stateKey": { "type": "object" },
    "sessionEpoch": { "type": "string", "pattern": "^[A-Za-z0-9_-]{22}$" },
    "stateGeneration": { "type": "integer", "minimum": 0, "maximum": 1000000 },
    "ledgerEpoch": { "type": "string", "pattern": "^[A-Za-z0-9_-]{22}$" },
    "transition": { "type": "object" },
    "predecessorMarkerId": { "type": "string" },
    "predecessorManifestSha256": { "type": "string" },
    "predecessorLedgerSha256": { "type": "string" },
    "observedSelectorRevision": {
      "type": "string",
      "pattern": "^(bootstrap|sha256:[a-f0-9]{64}|invalid:[a-f0-9]{64})$"
    },
    "manifestSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "candidateLedgerSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "providerRunMetadataSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "metadataSemanticSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "consumedInputSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "resultSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "traceSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "producingRunId": { "type": "string", "pattern": "^[1-9][0-9]{0,18}$" },
    "producingRunAttempt": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "acceptingRunId": { "type": "string", "pattern": "^[1-9][0-9]{0,18}$" },
    "acceptingRunAttempt": { "type": "integer", "minimum": 1, "maximum": 2147483647 },
    "acceptedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    }
  }
}
